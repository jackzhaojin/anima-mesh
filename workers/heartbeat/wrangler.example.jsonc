// TEMPLATE ONLY — the real deploy config lives in the INSTANCE repo's
// cloud/ workspace (D12: the engine is generic; deploying is an instance
// act). Copy, fill account_id and vars, deploy from there.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "animamesh-heartbeat",
  "main": "src/index.ts", // instance configs point at the engine checkout instead
  "account_id": "<CLOUDFLARE ACCOUNT ID>",
  "compatibility_date": "2026-07-01",
  "observability": { "enabled": true },
  "durable_objects": {
    "bindings": [
      { "name": "HEARTBEAT_DO", "class_name": "HeartbeatDO" },
      { "name": "DIRECTION_DO", "class_name": "DirectionDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["HeartbeatDO"] },
    { "tag": "v2", "new_sqlite_classes": ["DirectionDO"] }
  ],
  "vars": {
    "BRAIN_REPO": "<owner/name>",
    "BRAIN_REF": "main",
    "BEAT_TIMEZONE": "America/New_York",
    "BEAT_HOUR": "8"
    // "MOONSHOT_BASE_URL": "https://api.kimi.com/coding/v1", // when the key is endpoint-scoped
    // "DISCORD_PUBLIC_KEY": "<discord app verify key>",      // enables POST /interactions (inbound direction)
    // "DIRECTION_DAILY_CAP": "20",                           // direction budget (decision Q4)
    // "DIRECTION_GMAIL_POLL_MINUTES": "20",                  // Gmail poll cadence; 0/absent = inbound email off
    // "DIRECTION_GMAIL_ALLOWED_FROM": "<principal email>"    // only this sender's mail becomes directions
    // "MSGRAPH_TENANT": "<entra tenant id or domain>",        // 'onedrive' source; default "common"
    // "MSGRAPH_DRIVE_ID": "<drive id>",                       // a specific drive; default the consenting user's OneDrive
    // "MSGRAPH_CABINET_PATH": "<folder under the drive root>" // default the drive root
    // "GITHUB_DOCS_REPO": "<owner/docs-repo>",                // 'github-docs' source; absent = unconfigured
    // "GITHUB_DOCS_REF": "main",                              // default HEAD (the repo's default branch)
    // "GITHUB_DOCS_PATH": "<subpath>"                         // only list paths under this subpath
  }
  // Secrets (wrangler secret put): brain-repo auth is the GitHub App trio
  // GITHUB_APP_ID, GITHUB_APP_INSTALLATION_ID, GITHUB_APP_PRIVATE_KEY
  // (PKCS#8 PEM — convert GitHub's PKCS#1 download with
  // `openssl pkcs8 -topk8 -nocrypt`, and PIPE the file in:
  // `wrangler secret put GITHUB_APP_PRIVATE_KEY < app.pem`) — or the legacy
  // fine-grained PAT in GITHUB_TOKEN when no App var is set; plus
  // BEAT_TRIGGER_TOKEN;
  // cognition uses MOONSHOT_API_KEY and/or CLAUDE_CODE_OAUTH_TOKEN;
  // Discord surfaces use DISCORD_BOT_TOKEN and DISCORD_DM_USER_ID;
  // for inbound email also GMAIL_CLIENT_ID, GMAIL_CLIENT_SECRET,
  // GMAIL_REFRESH_TOKEN (needs gmail.modify scope), AGENT_EMAIL;
  // for the 'onedrive' read source MSGRAPH_CLIENT_ID, MSGRAPH_REFRESH_TOKEN
  // (+ MSGRAPH_CLIENT_SECRET only for confidential clients) — delegated
  // Files.Read.All consent, read-only; validate with GET /graph/check;
  // for the 'github-docs' read source GITHUB_DOCS_TOKEN (fine-grained PAT,
  // Contents READ-ONLY on the docs repo; falls back to GITHUB_TOKEN; public
  // repos need none) — validate with GET /docs/check.
  // anthropic-api uses subscription OAuth over plain fetch;
  // ANTHROPIC_API_KEY is not used by this adapter.
}
