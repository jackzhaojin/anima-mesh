{
  "name": "anima-mesh",
  "version": "0.9.2",
  "description": "AnimaMesh — an engine for running a company-of-0: a mesh of small agents over a git-backed OKF knowledge bundle, with humans as the approval gate.",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "anima-mesh": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run test && npm run typecheck:worker && npm run test:worker && npm run typecheck:web && npm run test:web",
    "cli": "tsx src/cli.ts",
    "typecheck:worker": "tsc -p workers/heartbeat/tsconfig.json",
    "test:worker": "cd workers/heartbeat && pnpm test",
    "test:live": "vitest run test/live-seams.test.ts test/live-eval.test.ts test/store-github-integration.test.ts",
    "typecheck:web": "tsc -p workers/web/tsconfig.json",
    "test:web": "cd workers/web && pnpm test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
